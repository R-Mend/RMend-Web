    "drizzle-orm": "^1.0.0-rc.4",
    "next": "^16.2.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.3.0",
    "react-tabs": "^6.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
